# =============================================================
# ĐỀ TÀI 31 — An toàn vật lý cho thiết bị IoT
# File cấu hình mẫu: sdkconfig.secureboot_flashenc
# =============================================================
# MỤC ĐÍCH
# --------
# Đây là trích đoạn cấu hình mẫu (dạng sdkconfig của ESP-IDF) minh họa
# cách BẬT hai cơ chế bảo vệ vật lý quan trọng nhất cho ESP32:
#   1) Secure Boot V2   -> chỉ cho phép chạy firmware đã được ký hợp lệ,
#                          chống nạp firmware giả mạo qua UART/JTAG.
#   2) Flash Encryption -> mã hóa toàn bộ nội dung chip Flash, chống
#                          việc đọc trộm firmware/dữ liệu khi kẻ tấn
#                          công tháo vỏ và dump Flash trực tiếp.
#
# LƯU Ý QUAN TRỌNG (đọc trước khi dùng)
# --------------------------------------
# - Đây là file THAM KHẢO Ở MỨC KHÁI NIỆM cho báo cáo/demo học thuật,
#   KHÔNG dùng để build và flash lên thiết bị thật nếu chưa hiểu rõ.
# - Trên phần cứng thật, bật Secure Boot/Flash Encryption có thể
#   KHÓA VĨNH VIỄN một số tùy chọn (ghi vào eFuse, không thể tắt lại).
#   Đề tài chỉ dùng để giải thích cơ chế trong báo cáo, không thao tác
#   trên thiết bị thật, đúng theo giới hạn an toàn đã cam kết (Mục 1.4).
# - Không có secret/khóa ký thật nào được đính kèm trong file này.

# ---------- 1) SECURE BOOT V2 ----------
# Bật Secure Boot phiên bản 2 (dùng cho chip ESP32-S2/S3/C3 trở lên;
# với ESP32 bản gốc dùng Secure Boot V1 - chỉ khác tên option).
CONFIG_SECURE_BOOT=y
CONFIG_SECURE_BOOT_V2_ENABLED=y

# Bắt buộc mọi ứng dụng nạp vào phải có chữ ký hợp lệ mới được chạy.
CONFIG_SECURE_SIGNED_APPS_NO_SECURE_BOOT=n
CONFIG_SECURE_SIGNED_ON_BOOT_NO_SECURE_BOOT=n

# Không cho phép rollback firmware xuống bản cũ chưa vá lỗi
# (chống replay firmware cũ có lỗ hổng đã biết).
CONFIG_SECURE_BOOT_ENABLE_AGGRESSIVE_KEY_REVOKE=n
CONFIG_SECURE_BOOTLOADER_ALLOW_ROLLBACK=n

# ---------- 2) FLASH ENCRYPTION ----------
# Bật mã hóa toàn bộ bộ nhớ Flash.
CONFIG_SECURE_FLASH_ENC_ENABLED=y

# Chế độ RELEASE: sau khi bật, không thể quay lại Flash dạng rõ.
# (Chế độ DEVELOPMENT chỉ nên dùng khi đang phát triển/thử nghiệm.)
CONFIG_SECURE_FLASH_ENCRYPTION_MODE_RELEASE=y

# Không cho phép ghi Flash rõ (plaintext) qua bootloader UART sau
# khi đã bật mã hóa — đóng đúng lỗ hổng "cổng debug để hở" đã nêu
# trong Mục 1.2 của báo cáo.
CONFIG_SECURE_FLASH_UART_BOOTLOADER_ALLOW_ENC=n
CONFIG_SECURE_FLASH_REQUIRE_ALREADY_ENABLED=n

# ---------- 3) KHÓA CỔNG DEBUG SAU TRIỂN KHAI ----------
# Vô hiệu hóa JTAG sau khi triển khai sản phẩm (ghi vào eFuse),
# ngăn kẻ tấn công dùng JTAG để đọc/ghi bộ nhớ trực tiếp.
CONFIG_ESP32_DISABLE_JTAG_ON_RELEASE=y

# Vô hiệu hóa console gỡ lỗi qua UART ROM sau khi boot xong ở bản
# release, chỉ giữ lại UART cho log ứng dụng (nếu cần).
CONFIG_ESP_CONSOLE_UART_NONE_ON_RELEASE=y

# =============================================================
# GHI CHÚ ÁP DỤNG VÀO BẢNG RỦI RO / CHECKLIST CỦA BÁO CÁO
# =============================================================
# - CONFIG_SECURE_BOOT_V2_ENABLED         -> khắc phục rủi ro "nạp
#   firmware giả mạo qua cổng debug" (Mục 1.2, Bảng rủi ro vật lý).
# - CONFIG_SECURE_FLASH_ENC_ENABLED       -> khắc phục rủi ro "dump
#   Flash để đọc trộm firmware/khóa bí mật".
# - CONFIG_ESP32_DISABLE_JTAG_ON_RELEASE  -> khắc phục rủi ro "kẻ tấn
#   công dùng JTAG để chiếm quyền điều khiển".
# - Các dòng trên tương ứng trực tiếp với các mục trong Checklist 20
#   tiêu chí (Chương 5) — nên trích dẫn lại các option này làm minh
#   chứng "cấu hình mẫu" khi trình bày từng tiêu chí đã đạt/chưa đạt.
